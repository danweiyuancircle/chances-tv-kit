{
  "name": "@chances/tv-ui",
  "version": "0.1.0",
  "description": "TV base UI components (E-prefixed) for Vue 3, built on @chances/tv-focus, tuned for legacy WebView (Chromium 53+).",
  "type": "module",
  "license": "MIT",
  "author": "chances",
  "keywords": [
    "tv",
    "vue3",
    "ui-components",
    "remote-control",
    "spatial-navigation",
    "chromium-53"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/focusable.css": "./dist/styles/focusable.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && cp -R src/styles dist/styles && cat src/styles/tokens.css src/styles/focusable.css dist/style.css > dist/style.full.css && mv dist/style.full.css dist/style.css",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@chances/tv-focus": "workspace:^",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@chances/tv-focus": "workspace:*",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.8"
  }
}
